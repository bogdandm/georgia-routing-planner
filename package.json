{
  "name": "georgia-routing-planner",
  "version": "0.0.0",
  "private": true,
  "description": "Offline-first Georgia hiking route planning application",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/bogdandm/georgia-routing-planner.git"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "e2e": "tsx tools/e2e/runPlaywright.ts",
    "catalog:audit": "tsx tools/catalog/notImplemented.ts audit",
    "catalog:build": "tsx tools/catalog/notImplemented.ts build",
    "diagnostics:inspect": "tsx tools/diagnostics/inspectDiagnostics.ts",
    "repo:audit": "tsx tools/repository/auditRepository.ts",
    "build:app": "vite build",
    "build": "pnpm typecheck && pnpm build:app",
    "check": "pnpm repo:audit && pnpm format:check && pnpm lint && pnpm test:coverage && pnpm test:integration && pnpm build"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "@mui/x-charts": "9.9.0",
    "@tanstack/react-query": "5.101.2",
    "@turf/area": "7.3.5",
    "@turf/boolean-point-in-polygon": "7.3.5",
    "@turf/helpers": "7.3.5",
    "@turf/intersect": "7.3.5",
    "@turf/point-to-line-distance": "7.3.5",
    "dexie": "4.4.4",
    "ky": "2.0.2",
    "maplibre-gl": "5.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-map-gl": "8.1.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/geojson": "7946.0.16",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "msw": "2.15.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
